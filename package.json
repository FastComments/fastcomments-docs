{
	"name": "fastcomments-docs",
	"dependencies": {
		"axios": "^0.24.0",
		"better-sqlite3": "^12.6.0",
		"diagrams": "^0.11.0",
		"express": "^4.18.2",
		"filewatcher": "^3.0.1",
		"handlebars": "^4.1.2",
		"highlight.js": "^11.5.0",
		"html-entities": "^2.1.0",
		"html-to-text": "^9.0.5",
		"marked": "^0.6.2",
		"md5": "^2.3.0",
		"minisearch": "^6.0.1",
		"puppeteer": "^7.1.0",
		"shortid": "^2.2.16",
		"uglify-js": "^3.7.3",
		"unescape": "^1.0.1"
	},
	"scripts": {
		"build-content": "node src/app",
		"build-windows": "build.bat",
		"build-posix": "bash build.sh",
		"build-sdks-content": "node src/sdk-guide-generator.js",
		"serve": "serve src/static/generated",
		"build-search-index": "node src/build-search-index-parallel.js",
		"build-search-index-rs": "cargo run --release --manifest-path rust/Cargo.toml -p fcdocs-indexer",
		"build-static-legacy": "bash build-static.sh",
		"custom-styling-legacy": "node src/custom-styling-guide-generator.js",
		"check-translations-legacy": "node src/check-translations.js",
		"cleanup-empty-translations-legacy": "node src/cleanup-empty-translations.js",
		"watch-legacy": "node src/watch.js",
		"start-search-engine": "node src/server-search-engine.js",
		"start-search-engine-rs": "cargo run --release --manifest-path rust/Cargo.toml -p fcdocs-server",
		"start-content-sidecar": "node src/content-sidecar.js",
		"dump-locales": "node scripts/dump-locales.js",
		"watch": "cargo run --release --manifest-path rust/Cargo.toml -p fcdocs-watcher",
		"check-translations": "cargo run --release --manifest-path rust/Cargo.toml -p fcdocs-trans -- check",
		"translate": "node src/translate-with-gpt.js",
		"migrate-locale-structure": "node src/migrate-to-locale-structure.js",
		"populate-snapshot": "node src/populate-snapshot.js",
		"fix-composer": "node src/content/sdks-checkout/sdk-php/fix-composer.js",
		"cleanup-empty-translations": "cargo run --release --manifest-path rust/Cargo.toml -p fcdocs-trans -- cleanup",
		"sitegen": "cargo run --release --manifest-path rust/Cargo.toml -p fcdocs-sitegen --",
		"sdkgen": "cargo run --release --manifest-path rust/Cargo.toml -p fcdocs-sdkgen"
	},
	"devDependencies": {
		"jscpd": "^4.2.3",
		"serve": "^11.2.0"
	}
}
